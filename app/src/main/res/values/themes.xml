<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Lightweight launch/window theme. The real UI theming is done in Compose
      (see ui/theme/Theme.kt). This only styles the very first window frame.
    -->
    <style name="Theme.Ledger" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Matches LightBackground in Color.kt so the first frame (and anything a
             transition might expose) is the theme color, never plain white. -->
        <item name="android:windowBackground">#FFF9FAEF</item>
    </style>
</resources>
